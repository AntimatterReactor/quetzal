require use std::io::stdio

fn alias [Vec<String> as x]sum_str
{
    x.map(|s| => s.to_int().expect("a number")).sum()
}

fn [::]main
{
    let `limited io = stdio::init()
    io.println(
        [
            io.print("input a number: ").get().nln(),
            io.print("input another number: ").get().nln()
        ].sum_str().to_str().with_format("result: %")
    )
    destroy io // you can also use `~io` achieve the same purpose
} -> void
