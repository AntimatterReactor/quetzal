use std::io::{print, println}
use std::vec::Vec

foreign str[] as x:
    fn sum_str(x) -> int:
        return x.map(|s| => s.to_int().expect("a number")).sum()

fn main:
    print("input a number: ")
    let a = getline()
    print("input another number: ")
    let b = getline()
    println([a,b].sum_str().to_str().with_format("result: %"))
